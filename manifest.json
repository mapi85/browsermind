{
  "manifest_version": 3,
  "name": "BrowserMind — AI Navigator",
  "version": "1.0.0",
  "description": "AI-powered side panel assistant. Navigate and automate the web in natural language. Multi-provider, extensible with custom tools.",
  "permissions": [
    "alarms",
    "sidePanel",
    "scripting",
    "tabs",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "BrowserMind",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "32": "icons/icon32.png"
  },
  "short_name": "BrowserMind"
}